# Copy to .env and fill in your keys: `cp .env.example .env`
# orchestrate.py loads .env at startup, so cron/launchd invocations get the
# keys without shell-profile tricks. Variables already set in the real
# environment take precedence over this file. .env is gitignored — keep real
# keys out of git.

# Bills all `claude -p` stage calls by API credit (see README "Cost & auth").
# To run on your Claude subscription's OAuth instead, comment this out here
# AND make sure it isn't set in your shell environment.
ANTHROPIC_API_KEY=sk-ant-...

# Aristotle (Harmonic's cloud Lean prover) — powers the free, non-gating
# formalization stage after the correctness gate. Get a key at
# https://aristotle.harmonic.fun/dashboard/keys. Without it (or with
# lean_enabled = false in config.toml) the stage is skipped.
ARISTOTLE_API_KEY=...
